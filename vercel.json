{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "builds": [
    {
      "src": "dist/server/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "dist/client/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/dist/client/assets/$1",
      "headers": { "cache-control": "public, max-age=31536000, immutable" }
    },
    {
      "src": "/favicon.png",
      "dest": "/dist/client/favicon.png"
    },
    {
      "src": "/robots.txt",
      "dest": "/dist/client/robots.txt"
    },
    {
      "src": "/sitemap.xml",
      "dest": "/dist/client/sitemap.xml",
      "headers": { "content-type": "application/xml", "cache-control": "public, max-age=3600" }
    },
    {
      "src": "/llms.txt",
      "dest": "/dist/client/llms.txt"
    },
    {
      "src": "/og/(.*)",
      "dest": "/dist/client/og/$1",
      "headers": { "cache-control": "public, max-age=31536000, immutable" }
    },
    {
      "src": "/(.*)",
      "dest": "/dist/server/server.js"
    }
  ]
}
